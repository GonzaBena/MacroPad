{
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["DOM", "ESNext"],
    "allowJs": false,
    "checkJs": false,
    "jsx": "react",
    "strict": true,
    "noImplicitAny": true,
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "dist-ts",
    "composite": true
  },
  "exclude": ["node_modules", "dist", "dist-ts", "renderer/js/temp_build"]
}
