{
  "name": "pokepad",
  "version": "1.1.1",
  "description": "PokePad - Control your PC with Arduino",
  "author": "Atlas",
  "repository": {
    "type": "git",
    "url": "https://github.com/GonzaBena/MacroPad.git"
  },
  "main": "dist-ts/main.js",
  "scripts": {
    "start": "electron . --enable-logging",
    "dev": "concurrently \"tsc -p tsconfig.main.json --watch\" \"tsc -p tsconfig.renderer.json --watch\" \"npm run bundle:cm:watch\" \"electron . --enable-logging\"",
    "build": "npm run compile && electron-builder",
    "compile": "tsc -p tsconfig.main.json && tsc -p tsconfig.renderer.json && npm run bundle:cm",
    "bundle:cm": "esbuild src/codemirror-bundle.ts --bundle --format=iife --global-name=CM --outfile=renderer/js/vendor/codemirror.bundle.js --minify",
    "bundle:cm:watch": "esbuild src/codemirror-bundle.ts --bundle --format=iife --global-name=CM --outfile=renderer/js/vendor/codemirror.bundle.js --watch",
    "test": "jest",
    "test:coverage": "jest --coverage"
  },
  "build": {
    "appId": "com.atlas.pokepad",
    "productName": "Pokepad",
    "files": [
      "dist-ts/**/*",
      "renderer/**/*",
      "assets/**/*",
      "package.json",
      "plugins/**/*",
      "!**/*.ts",
      "!**/*.tsbuildinfo"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/logo.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/logo.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/logo.png"
    }
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.2",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.43.0",
    "@nut-tree-fork/nut-js": "^4.2.6",
    "@serialport/parser-readline": "^12.0.0",
    "chokidar": "^3.6.0",
    "dompurify": "^3.4.3",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "marked": "^18.0.3",
    "serialport": "^12.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.3",
    "@babel/preset-typescript": "^7.28.5",
    "@electron/rebuild": "^4.0.4",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.7.0",
    "@types/serialport": "^8.0.5",
    "babel-jest": "^29.7.0",
    "concurrently": "^9.2.1",
    "electron": "^40.0.0",
    "electron-builder": "^26.0.0",
    "electron-reload": "^2.0.0-alpha.1",
    "esbuild": "^0.28.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.4.1",
    "typescript": "^6.0.3"
  }
}
