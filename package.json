{
  "name": "poketech",
  "version": "0.0.1",
  "description": "PokePad - Control your PC with Arduino",
  "author": "Atlas",
  "main": "main.js",
  "scripts": {
    "start": "electron . --enable-logging",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.atlas.pokepad",
    "productName": "Pokepad",
    "win": {
      "target": "nsis",
      "icon": "assets/logo.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/logo.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/logo.png"
    }
  },
  "dependencies": {
    "@nut-tree-fork/nut-js": "^4.2.6",
    "@serialport/parser-readline": "^12.0.0",
    "serialport": "^12.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0",
    "electron-reload": "^2.0.0-alpha.1"
  }
}