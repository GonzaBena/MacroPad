{
  "name": "pokepad",
  "version": "0.2.0",
  "description": "PokePad - Control your PC with Arduino",
  "author": "Atlas",
  "repository": {
    "type": "git",
    "url": "https://github.com/GonzaBena/MacroPad.git"
  },
  "main": "dist-ts/main.js",
  "scripts": {
    "start": "electron . --enable-logging",
    "dev": "concurrently \"tsc -p tsconfig.main.json --watch\" \"tsc -p tsconfig.renderer.json --watch\" \"electron . --enable-logging\"",
    "build": "npm run compile && electron-builder",
    "compile": "tsc -p tsconfig.main.json && tsc -p tsconfig.renderer.json",
    "test": "jest",
    "test:coverage": "jest --coverage"
  },
  "build": {
    "appId": "com.atlas.pokepad",
    "productName": "Pokepad",
    "win": {
      "target": "nsis",
      "icon": "assets/logo.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/logo.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/logo.png"
    }
  },
  "dependencies": {
    "@nut-tree-fork/nut-js": "^4.2.6",
    "@serialport/parser-readline": "^12.0.0",
    "electron-updater": "^6.8.3",
    "marked": "^18.0.3",
    "serialport": "^12.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.3",
    "@electron/rebuild": "^4.0.4",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.7.0",
    "@types/serialport": "^8.0.5",
    "babel-jest": "^29.7.0",
    "concurrently": "^9.2.1",
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0",
    "electron-reload": "^2.0.0-alpha.1",
    "jest": "^29.7.0",
    "typescript": "^6.0.3"
  }
}
